type Query {
    shows(titleFilter: String): [Show!]
    doNotCodeGen(titleFilter: String): [Show!]
    theaters: [Theater!]
}

type Mutation {
    createShow(showInput: ShowInput!): Show!
    addComment(showId: Int!, comment: String!): Comment
}

type Theater {
    id: ID!
    name: String!
    location: String!
}